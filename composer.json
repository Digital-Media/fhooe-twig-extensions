{
    "name": "fhooe/twig-extensions",
    "description": "A collection of Twig extensions for other fhooe packages",
    "license": "MIT",
    "type": "library",
    "version": "3.0.0",
    "keywords": [
        "Twig",
        "extensions",
        "education",
        "routing",
        "sessions"
    ],
    "authors": [
        {
            "name": "Wolfgang Hochleitner",
            "email": "wolfgang.hochleitner@fh-hagenberg.at",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "fhooe/router": "^3.0",
        "twig/twig": "^3.24"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.50",
        "friendsofphp/php-cs-fixer": "^3.94",
        "pestphp/pest": "^4.4",
        "phpstan/phpstan": "^2.1"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../fhooe-router",
            "options": {
                "symlink": false
            }
        }
    ],
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "Fhooe\\Twig\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "pest": "pest",
        "phpstan": "phpstan analyse src --memory-limit=-1 --level 9 || true",
        "test": [
            "@cs-check",
            "@phpstan",
            "@pest"
        ]
    }
}
