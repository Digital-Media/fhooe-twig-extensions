{
    "name": "fhooe/twig-extensions",
    "description": "A collection of Twig extensions for other fhooe packages",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "Twig",
        "extensions",
        "education",
        "routing",
        "sessions"
    ],
    "authors": [
        {
            "name": "Wolfgang Hochleitner",
            "email": "wolfgang.hochleitner@fh-hagenberg.at",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "fhooe/router": "^2.0",
        "twig/twig": "^3.20"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.45",
        "pestphp/pest": "^3.7",
        "phpstan/phpstan": "^2.1"
    },
    "minimum-stability": "dev",
    "autoload": {
        "psr-4": {
            "Fhooe\\Twig\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "pest": "pest",
        "phpstan": "phpstan analyse src --memory-limit=-1 --level 9 || true",
        "test": [
            "@phpstan",
            "@pest"
        ]
    }
}
